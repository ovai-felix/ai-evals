# aeval orchestrator environment variables
# Copy to .env and customize

# TimescaleDB
POSTGRES_USER=aeval
POSTGRES_PASSWORD=aeval_dev
POSTGRES_DB=aeval
DATABASE_URL=postgresql://aeval:aeval_dev@db:5432/aeval

# Redis
REDIS_URL=redis://redis:6379/0

# Ollama (host.docker.internal for Docker-to-host access)
OLLAMA_HOST=http://host.docker.internal:11434

# Orchestrator
ORCHESTRATOR_PORT=8081

# Registry
REGISTRY_PORT=8082

# Dashboard
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8081

# Intelligence (Phase 5 — adaptive eval generation)
INTELLIGENCE_GENERATOR_MODEL=gemma3
INTELLIGENCE_CALIBRATION_MODEL=gemma3
